{
  "name": "@Krytz/server",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "worker": "node src/worker.js",
    "build": "echo 'No build step needed for JS'",
    "db:migrate": "psql $DATABASE_URL -f prisma/schema.v3.sql",
    "db:seed": "node prisma/seed.js",
    "create-user": "node scripts/create-user.js",
    "test": "node tests/unit/run-tests.cjs",
    "test:live": "vitest run --pool=threads",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "autocannon": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "openai": "^4.70.0",
    "pg": "^8.20.0",
    "uuid": "^14.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.4.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.0"
  }
}
