+
+function MemoryList({ title, items, empty }) {
+  return (
+    <div className="strategy-memory-list">
+      <span className="strategy-mini-heading">{title}</span>
+      {items.length === 0 ? (
+        <span className="strategy-muted-line">{empty}</span>
